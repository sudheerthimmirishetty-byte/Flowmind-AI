# ============================================================
# FlowMind AI — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ─── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Frontend Origin (CORS) ──────────────────────────────────
# Comma-separated list of allowed origins
FRONTEND_URL=http://localhost:5173

# ─── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── JWT Authentication ───────────────────────────────────────
# Use a long, random, hard-to-guess string (min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-replace-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Bcrypt ──────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ─────────────────────────────────────────────────
# Options: error | warn | info | debug
LOG_LEVEL=info

# ─── Supabase Storage (for Document Uploads) ─────────────────
SUPABASE_STORAGE_BUCKET=flowmind-documents
